{
  "name": "zervi-pattern-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first pattern intelligence system for Zervi car seat cover manufacturing",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "build": "npm run build --workspaces",
    "test": "npm test --workspaces",
    "lint": "npm run lint --workspaces",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "python scripts/migrate.py"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
